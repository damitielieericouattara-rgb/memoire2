// Fichier: /frontend/manifest.json
{
    "name": "E-Commerce Intelligent",
    "short_name": "EComm",
    "description": "Votre boutique en ligne intelligente et inclusive",
    "start_url": "/frontend/pages/dashboard.html",
    "display": "standalone",
    "background_color": "#ffffff",
    "theme_color": "#2563eb",
    "orientation": "portrait-primary",
    "lang": "fr",
    "icons": [
        {
            "src": "/frontend/assets/images/icons/icon-72x72.png",
            "sizes": "72x72",
            "type": "image/png",
            "purpose": "maskable any"
        },
        {
            "src": "/frontend/assets/images/icons/icon-96x96.png",
            "sizes": "96x96",
            "type": "image/png",
            "purpose": "maskable any"
        },
        {
            "src": "/frontend/assets/images/icons/icon-128x128.png",
            "sizes": "128x128",
            "type": "image/png",
            "purpose": "maskable any"
        },
        {
            "src": "/frontend/assets/images/icons/icon-192x192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable any"
        },
        {
            "src": "/frontend/assets/images/icons/icon-512x512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable any"
        }
    ],
    "categories": ["shopping", "lifestyle"],
    "shortcuts": [
        {
            "name": "Catalogue",
            "url": "/frontend/pages/catalogue.html",
