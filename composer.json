// Fichier: /composer.json
{
    "name": "ecommerce/intelligent",
    "description": "E-Commerce Intelligent & Inclusif — Projet L3 Informatique",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "firebase/php-jwt": "^6.10",
        "cboden/ratchet": "^0.4.4",
        "mpdf/mpdf": "^8.2",
        "phpqrcode/phpqrcode": "^1.0",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "backend/"
        },
        "classmap": [
            "backend/core",
            "backend/models",
            "backend/controllers",
            "backend/middleware",
            "backend/services",
            "backend/config",
            "backend/utils"
        ]
    },
    "scripts": {
        "start": "php -S localhost:8000 -t backend",
        "test": "phpunit tests"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    }
}