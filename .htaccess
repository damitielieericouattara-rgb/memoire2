## SneakX — Configuration Apache
## Activer mod_rewrite et mod_headers

Options -Indexes
Options +FollowSymLinks

# ── SÉCURITÉ ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Protéger les fichiers PHP backend (accès direct bloqué sauf API)
<FilesMatch "^(config|classes|models|controllers|middlewares)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── URL REWRITING ────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /sneakx/

    # Rediriger root vers le frontend
    RewriteRule ^$ frontend/pages/index.html [L]

    # API backend — garder les paramètres
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/auth(.*)$         backend/api/auth.php$1 [QSA,L]
    RewriteRule ^api/produits(.*)$     backend/api/produits.php$1 [QSA,L]
    RewriteRule ^api/panier(.*)$       backend/api/panier.php$1 [QSA,L]
    RewriteRule ^api/commandes(.*)$    backend/api/commandes.php$1 [QSA,L]
    RewriteRule ^api/paiement(.*)$     backend/api/paiement.php$1 [QSA,L]
    RewriteRule ^api/livraison(.*)$    backend/api/livraison.php$1 [QSA,L]
    RewriteRule ^api/notifications(.*)$ backend/api/notifications.php$1 [QSA,L]
    RewriteRule ^api/wishlist(.*)$     backend/api/wishlist.php$1 [QSA,L]
    RewriteRule ^api/admin(.*)$        backend/api/admin.php$1 [QSA,L]

    # SPA frontend fallback
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^pages/(.*)$ frontend/pages/$1 [L]
</IfModule>

# ── CACHE & PERFORMANCE ──────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg  "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType text/javascript "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# ── COMPRESSION GZIP ─────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>
